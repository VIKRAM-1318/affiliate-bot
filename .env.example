# ── Affiliate Bot — GitHub Secrets Reference ──────────────────────────────────
# Copy these to: GitHub Repo → Settings → Secrets and variables → Actions
# DO NOT commit actual values to this file or to the repo!

# 1. Gemini AI (Free — 1,500 req/day)
GEMINI_API_KEY=AIzaSyCpbV36CbVjE7aVZIdaBVEr3DsadW-4LQU

# 2. Google Blogger Auth (Run setup/get_blogger_token.py to generate this)
#    Paste the entire JSON output as one line
GOOGLE_CREDENTIALS_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","token_uri":"..."}

# 3. Blogger Blog ID (find in your Blogger dashboard URL)
#    e.g. https://www.blogger.com/blog/posts/XXXXXXXXXXXX  ← that number is the Blog ID
BLOGGER_BLOG_ID=YOUR_BLOG_ID_HERE

# 4. Pinterest (run: python src/pinterest.py to get Board ID after setting token)
PINTEREST_ACCESS_TOKEN=YOUR_PINTEREST_ACCESS_TOKEN
PINTEREST_BOARD_ID=YOUR_BOARD_ID

# 5. Amazon Affiliate
AMAZON_ASSOCIATE_ID=smartstudy071-21

# 6. Blog URL
BLOG_URL=codergadgetfinds.blogspot.com
